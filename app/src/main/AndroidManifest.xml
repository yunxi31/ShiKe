<?xml version="1.0" encoding="utf-8"?>
<manifest package="com.pomodoroalert"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:label="番茄提醒"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PomodoroAlert">
        <activity android:name=".ui.AlarmWakeUpActivity"
            android:exported="true"
            android:showWhenLocked="true"
            android:turnScreenOn="true" />
        <activity android:name=".ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.PomodoroAlert">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <service android:name=".service.TimerService"
            android:foregroundServiceType="mediaProjection|dataSync|location|connectedDevice|mediaPlayback|mediaProjection|phoneCall|systemExempted" />
        <receiver android:name=".receiver.ExactAlarmReceiver" />
    </application>
</manifest>
